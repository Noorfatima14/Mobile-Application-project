{
  "expo": {
    "name": "Vectis",
    "slug": "Vectis",
    "scheme": "leverage",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/vectis-logo.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0B0B0D"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.yourcompany.leverage"
    },
    "android": {
      "package": "com.yourcompany.leverage"
    },
    "plugins": [
      "expo-router"
    ],
    "extra": {},
    "experiments": {
      "typedRoutes": true
    }
  }
}
